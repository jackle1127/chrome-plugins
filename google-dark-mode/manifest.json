{
  "manifest_version": 3,
  "name": "Google Docs Dark Mode",
  "version": "1.2.0",
  "description": "Dark mode for Google Docs and Sheets - inverts colors while preserving images",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://docs.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["canvas-patch.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://docs.google.com/*"],
      "js": ["content.js"],
      "css": ["dark.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
